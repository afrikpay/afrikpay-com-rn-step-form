{
  "name": "@afrikpay/rn-step-form",
  "version": "2.0.6",
  "description": "Declarative multi-step form builder for React Native — NativeWind, RHF, Zod",
  "source": "./src/index.tsx",
  "main": "./lib/module/index.js",
  "react-native": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "react-native": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @afrikpay/rn-step-form-example",
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "build": "tsc",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afrikpay/afrikpay-com-rn-step-form.git"
  },
  "author": "ukev-ap <k.tchonkap@afrikpay.com> (https://github.com/afrikpay)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/afrikpay/afrikpay-com-rn-step-form.git/issues"
  },
  "homepage": "https://github.com/afrikpay/afrikpay-com-rn-step-form.git#readme",
  "publishConfig": {
    "registry": "https://europe-west4-npm.pkg.dev/prod-app-base-060623/afrikpay-npm/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@expo/vector-icons": "^13.0.0",
    "@gorhom/bottom-sheet": ">=5",
    "@react-native-community/datetimepicker": "6.7.3",
    "@react-native/eslint-config": "^0.78.0",
    "@react-native/eslint-plugin": "^0.84.1",
    "@types/jest": "^29.5.5",
    "@types/react": "~18.0.27",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "commitlint": "^19.6.1",
    "del-cli": "^5.1.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "expo-document-picker": ">=14",
    "jest": "^29.7.0",
    "lucide-react-native": ">=0.300",
    "prettier": "^3.0.3",
    "react": "18.2.0",
    "react-hook-form": "^7.56.4",
    "react-native": "0.71.14",
    "react-native-builder-bob": "^0.38.3",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "~2.14.4",
    "react-native-svg": "^15.15.4",
    "typescript": "5.2.2"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": ">=5",
    "@react-native-community/datetimepicker": ">=7",
    "expo-document-picker": ">=14",
    "lucide-react-native": ">=0.300",
    "nativewind": ">=4",
    "react": ">=18",
    "react-hook-form": ">=7.50",
    "react-native": ">=0.73",
    "react-native-reanimated": ">=3",
    "react-native-svg": "*"
  },
  "peerDependenciesMeta": {
    "@hookform/resolvers": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.49.2"
  }
}
